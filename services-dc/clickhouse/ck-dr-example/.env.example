# =============================================================================
# clickhouse-rd — Environment configuration
# =============================================================================
# Copy this file to .env and adjust values as needed.
#   cp .env.example .env
#
# ⚠ TTL values (move to cold, delete on aggregates) are configured directly
#   in clickhouse/initdb.d/000-init.sh and are not overridable via .env.
# =============================================================================

# --- Pinned image versions ------------------------------------------------
CLICKHOUSE_VERSION=25.3
MINIO_VERSION=RELEASE.2025-01-20T14-49-07Z
MINIO_MC_VERSION=RELEASE.2025-01-17T23-25-50Z

# --- ClickHouse -----------------------------------------------------------
CLICKHOUSE_DATABASE=clickhouse_rd
CLICKHOUSE_USER=rd_user
CLICKHOUSE_PASSWORD=rd_local_password

# Ports — host-side mapping
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9004

# --- MinIO ----------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# S3 API exposed on 9002 (9000 is used inside the Compose network)
# Console on 9003
MINIO_API_PORT=9002
MINIO_CONSOLE_PORT=9003

# --- Buckets --------------------------------------------------------------
MINIO_DATA_BUCKET=clickhouse-data
MINIO_BACKUP_BUCKET=clickhouse-backups

# --- TTL settings (reference — not wired as env vars in this version) -----
# events_raw        → TTL move to cold volume after  5 MINUTES
# events_raw        → TTL delete after                10 MINUTES
#
# To change these values, edit clickhouse/initdb.d/000-init.sh directly.
