# OpenObserve Environment Variables
ZO_ROOT_USER_EMAIL=admin@example.com
ZO_ROOT_USER_PASSWORD=StrongPassword123!
ZO_DATA_DIR=/data

# Data Retention Configuration (5 days)
ZO_COMPACT_DATA_RETENTION_DAYS=5
ZO_COMPACT_INTERVAL=600

# Indexing Optimization
ZO_ENABLE_INVERTED_INDEX=true
ZO_FEATURE_QUERY_REMOVE_FILTER_WITH_INDEX=true
ZO_FEATURE_QUERY_PARTITION_STRATEGY=file_num

# Compaction Optimization (for 5-day retention)
ZO_COMPACT_MAX_FILE_SIZE=128
ZO_COMPACT_FAST_MODE=true
ZO_COMPACT_STRATEGY=file_time

# Performance Tuning
ZO_COMPACT_SYNC_TO_DB_INTERVAL=900
ZO_COMPACT_DELETE_FILES_DELAY_HOURS=1
ZO_COMPACT_JOB_RUN_TIMEOUT=300

# Disable telemetry for staging
ZO_TELEMETRY=false
